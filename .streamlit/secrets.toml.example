# Required Streamlit secrets for Memo Chef
# Copy this file to secrets.toml and fill in real values.
# NEVER commit secrets.toml to version control.
#
# Generate password hashes with:
#   python -c "from user_management import hash_password; print(hash_password('your-password'))"

ANTHROPIC_API_KEY = "sk-ant-..."
CREDITS_DATABASE_URL = "postgresql://user:password@host/neondb?sslmode=require"

# App URL for invite links (used in email invites)
APP_URL = "https://memochef.streamlit.app"

# SMTP config for email invites (optional — if omitted, invite links are shown for manual sharing)
# SMTP_HOST = "smtp.gmail.com"
# SMTP_PORT = 587
# SMTP_USER = "memochef@company.com"
# SMTP_PASSWORD = "app-password"
# SMTP_FROM_NAME = "Memo Chef"

# Legacy user definitions (fallback — DB-backed users are preferred)
# Users can now be managed via the Admin Panel in the web UI.
[users.brandon]
password_hash = "salt_hex:hash_hex"
role = "admin"
credits_per_week = 20

[users.john]
password_hash = "salt_hex:hash_hex"
role = "user"
credits_per_week = 5
